# Copy to terraform.tfvars and fill in real values. terraform.tfvars is gitignored.
subscription_id     = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
resource_group_name = "emapp-rg"
location            = "East US"
cluster_name        = "emapp-aks"
kubernetes_version  = "1.31"

# Free tier is enough for a learning/pet project. Set to "Standard" for a
# financially backed SLA, or "Premium" to unlock AKSLongTermSupport.
sku_tier     = "Free"
support_plan = "KubernetesOfficial"

# Small, cost-efficient B-series VMs by default. Scale up for real workloads.
system_node_vm_size = "Standard_B2s"
worker_node_vm_size = "Standard_B2s"

worker_autoscaling_enabled = true
worker_node_min_count      = 1
worker_node_max_count      = 3
worker_node_count          = 1    # used only when autoscaling is disabled

os_disk_size_gb = 50

environment = "production"

tags = {
  Owner      = "your-team"
  CostCenter = "engineering"
}
